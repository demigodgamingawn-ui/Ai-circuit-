service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidProject(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.description is string && data.description.size() < 1000 &&
             data.code is string &&
             data.authorId is string &&
             data.authorName is string &&
             data.authorPhoto is string &&
             data.likes is number;
    }

    // Projects collection
    match /projects/{projectId} {
      allow read: if true; // Publicly readable
      allow create: if isAuthenticated() && isValidProject(request.resource.data) && request.resource.data.authorId == request.auth.uid;
      allow update: if isAuthenticated() && (
        // Allow anyone to increment likes
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']) && request.resource.data.likes == resource.data.likes + 1) ||
        // Allow owner to edit
        (isOwner(resource.data.authorId) && isValidProject(request.resource.data))
      );
      allow delete: if isOwner(resource.data.authorId);
    }

    // Users collection (for profiles)
    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }
  }
}
