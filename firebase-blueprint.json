{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A circuit project with code and metadata",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Project title" },
        "description": { "type": "string", "description": "Project description" },
        "circuit": { "type": "object", "description": "JSON representation of the circuit" },
        "code": { "type": "string", "description": "Arduino C++ code" },
        "authorId": { "type": "string", "description": "UID of the creator" },
        "authorName": { "type": "string", "description": "Display name of the creator" },
        "authorPhoto": { "type": "string", "description": "Photo URL of the creator" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "likes": { "type": "number", "description": "Number of likes" }
      },
      "required": ["title", "description", "code", "authorId", "authorName", "authorPhoto", "likes"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Public project feed"
    }
  }
}
